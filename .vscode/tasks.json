{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Sass Watch",
            "type": "shell",
            "command": "sass --watch style.scss style.css",
            "options": {
                "cwd": "${workspaceFolder}/src/components/styles"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": "$node-sass"
        }
    ]
}